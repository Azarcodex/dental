generator client {
  provider      = "prisma-client-js"
  output        = "../src/prisma-client"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(uuid())
  name      String
  email     String?   @unique
  password  String
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  address   String?
  phone     String?
  username  String    @unique
}

model Doctor {
  id              String                    @id @default(uuid())
  firstName       String
  lastName        String?
  email           String                    @unique
  phone           String
  gender          String
  profilePhoto    String?
  specialization  String
  consultationFee Float
  status          String
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  appointments    Appointment[]
  blocks          DoctorAvailabilityBlock[]
  exceptions      DoctorException[]
  schedules       DoctorSchedule[]
}

model Patient {
  id           String        @id @default(uuid())
  fullName     String
  gender       String
  phone        String        @unique
  age          Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  displayId    String?       @unique
  appointments Appointment[]
}

model DoctorSchedule {
  id           String @id @default(uuid())
  doctorId     String
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int
  doctor       Doctor @relation(fields: [doctorId], references: [id])
}

model DoctorAvailabilityBlock {
  id        String @id @default(uuid())
  doctorId  String
  dayOfWeek Int
  startTime String
  endTime   String
  doctor    Doctor @relation(fields: [doctorId], references: [id])
}

model DoctorException {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime
  isFullDay Boolean  @default(false)
  startTime String?
  endTime   String?
  reason    String?
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Appointment {
  id             String   @id @default(uuid())
  doctorId       String
  patientId      String
  date           DateTime
  startTime      String
  endTime        String
  status         String
  createdAt      DateTime @default(now())
  specialization String
  token          String?
  bookingType    String   @default("Online")
  doctor         Doctor   @relation(fields: [doctorId], references: [id])
  patient        Patient  @relation(fields: [patientId], references: [id])

  @@unique([doctorId, date, startTime])
  @@unique([doctorId, date, token])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Review {
  id          String   @id @default(uuid())
  name        String
  description String
  rating      Int
  status      String   @default("pending") // "pending", "approved", "rejected"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(uuid())
  imageUrl  String
  publicId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

